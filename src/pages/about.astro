---
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ABOUT_TITLE } from "../lib/constants";
---

<BaseLayout pageTitle={ABOUT_TITLE} />
<div class="body-wrapper">
	<section class="hero">
		<p class="hero-eyebrow">LOVE AND DEEPSPACE</p>
		<h1 class="hero-title">About <em>Rika</em></h1>
		<p class="hero-sub">
			Just a regular, penny-pinching Love & Deepspace player who spends an
			unhealthy amount of time in Glint Photobooth instead of fangirling
			over love interests. And also guilty of reading every card story.
		</p>
	</section>
	<Footer />
</div>
