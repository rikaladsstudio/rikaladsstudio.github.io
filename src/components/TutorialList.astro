---
import type { ImageMetadata } from "astro";
import makeupTutorials from "../data/makeup_tutorials.json";
import TutorialCard from "./TutorialCard.astro";

// Convert date from "YYYY-MM-DD" to "Month Year" format
const formatDate = (dateString: string) => {
    const date = new Date(dateString);
    if (date === null) {
        return "";
    }
    return date.toLocaleDateString("en-US", {
        month: "long",
        year: "numeric",
    });
};

// Glob all potential images into a map
const allThumbnails = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/tutorials/*.webp",
    { eager: true },
);

// Process and render
const thumbnailList = Object.values(makeupTutorials.tutorials).map(
    (tutorial) => {
        const thumbnailModule =
            allThumbnails[`/src/assets/tutorials/${tutorial.id}.webp`];
        return {
            src: thumbnailModule
                ? thumbnailModule.default.src
                : "https://placehold.co/500",
            alt: tutorial.title,
            dateFormattedString: formatDate(tutorial.date),
            ...tutorial,
        };
    },
);
---

<!-- display total tutorial count -->
<div id="makeup-tutorial-container">
    <div id="tutorial-count">
        {makeupTutorials.tutorials.length} TUTORIAL{
            makeupTutorials.tutorials.length !== 1 ? "S" : ""
        }
    </div>
    <section id="makeup-tutorials-section">
        <div class="grid">
            {
                thumbnailList.map((tutorial) => (
                    <TutorialCard
                        thumbnailPath={tutorial.src}
                        title={tutorial.title}
                        date={tutorial.dateFormattedString}
                        postUrl={tutorial.postUrl}
                    />
                ))
            }
        </div>
    </section>
</div>
